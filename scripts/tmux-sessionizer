#!/usr/bin/env bash

claude_mode=0
if [[ $1 == "-c" || $1 == "--claude" ]]; then
  claude_mode=1
  shift
fi

if [[ $# -eq 1 ]]; then
  selected=$1
else
  dirs=(
    "insert/your/directory/here"
    "insert/your/directory/here"
  )
  # running sessions, tagged "(running)" so we can tell them apart from dirs
  sessions=$(tmux list-sessions -F '#{session_name} (running)' 2>/dev/null)
  running=$(tmux list-sessions -F '#{session_name}' 2>/dev/null)
  # project dirs, minus any whose session is already running (dedup)
  dir_lines=""
  for dir in "${dirs[@]}"; do
    name=$(basename "$dir" | tr . _)
    printf '%s\n' "$running" | grep -qxF "$name" || dir_lines+="$dir"$'\n'
  done
  selected=$( { [[ -n $sessions ]] && printf '%s\n' "$sessions"; printf '%s' "$dir_lines"; } | fzf --height 40% --layout reverse --border)
fi

if [[ -z $selected ]]; then
  exit 0
fi

# Picked a running session → just attach/switch to it
if [[ $selected == *" (running)" ]]; then
  session_name=${selected% (running)}
  if [[ -z $TMUX ]]; then
    tmux attach-session -t "$session_name"
  else
    tmux switch-client -t "$session_name"
  fi
  exit 0
fi

selected_name=$(basename "$selected" | tr . _)
if [[ $claude_mode -eq 1 ]]; then
  selected_name="${selected_name}-claude"
fi

tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
  tmux new-session -ds $selected_name -c "$selected"
  [[ $claude_mode -eq 1 ]] && tmux send-keys -t $selected_name 'claude' C-m
  tmux attach-session -t $selected_name
  exit 0
fi

if ! tmux has-session -t=$selected_name 2> /dev/null; then
  tmux new-session -ds $selected_name -c "$selected"
  [[ $claude_mode -eq 1 ]] && tmux send-keys -t $selected_name 'claude' C-m
fi

tmux switch-client -t $selected_name

